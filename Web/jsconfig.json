{
	"compilerOptions": {
		"checkJs"			: true,
		"noEmit"			: true,
		"target"			: "ES2022",
		"lib"				: [ "ES2022", "DOM" ],
		"module"			: "ES2022",
		"moduleResolution"	: "bundler",
		"strict"			: false,
		"noImplicitAny"		: false
	},
	"include": [ "*.js" ],
	"exclude": [ "eslint.config.js", "node_modules" ]
}
